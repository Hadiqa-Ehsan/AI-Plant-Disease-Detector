<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent center -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="2dp"
                android:color="#4CAF50"
                android:dashWidth="10dp"
                android:dashGap="5dp" />
        </shape>
    </item>

    <!-- Corners -->
    <item android:top="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="4dp"
                android:color="#4CAF50" />
            <size android:width="40dp" android:height="40dp" />
        </shape>
    </item>
    <item android:top="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="4dp"
                android:color="#4CAF50" />
            <size android:width="40dp" android:height="40dp" />
        </shape>
    </item>
    <item android:bottom="0dp" android:left="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="4dp"
                android:color="#4CAF50" />
            <size android:width="40dp" android:height="40dp" />
        </shape>
    </item>
    <item android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="4dp"
                android:color="#4CAF50" />
            <size android:width="40dp" android:height="40dp" />
        </shape>
    </item>
</layer-list>